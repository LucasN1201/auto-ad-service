# Database (used by backend, worker, telegram-bot)
# DATABASE_URL=postgresql://postgres:postgres@db:5432/autoad

# JWT for API (backend)
JWT_SECRET_KEY=change-me-in-production-use-long-secret

# Default admin (optional; seeded by migration if not changed)
# ADMIN_USERNAME=admin
# ADMIN_PASSWORD=admin123

# Scraper worker (optional)
# SCRAPE_INTERVAL_SEC=300
# MAX_LISTINGS=100

# Frontend: URL the browser uses to call the API (e.g. http://localhost:8000)
NEXT_PUBLIC_API_URL=http://localhost:8000

# Telegram bot (required for bot service)
TELEGRAM_BOT_TOKEN=your_bot_token_from_botfather
OPENAI_API_KEY=your_openai_api_key
